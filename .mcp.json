{
  "mcpServers": {
    "mcp-pinterest": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@striderlabs/mcp-pinterest"
      ],
      "env": {
        "PINTEREST_EMAIL": "${PINTEREST_EMAIL}",
        "PINTEREST_PASSWORD": "${PINTEREST_PASSWORD}",
        "PINTEREST_HEADLESS": "true"
      }
    },
    "reddit": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-reddit"
      ],
      "env": {}
    },
    "chrome": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ]
    }
  }
}