{
  "mcpServers": {
    "reddit": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-reddit"
      ],
      "env": {}
    },
    "chrome": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ]
    }
  }
}